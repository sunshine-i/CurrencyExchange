<UserControl x:Class="CurrencyExchange.Client.Views.ExchangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B0E11">

    <UserControl.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#848E9C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected item text — explicit foreground so it's always readable -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="12 0 0 0"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="#EAECEF"
                                                  TextBlock.FontFamily="Segoe UI"
                                                  TextBlock.FontSize="14"/>

                                <!-- Dropdown arrow -->
                                <TextBlock Grid.Column="1" Text="▾"
                                           Foreground="#848E9C" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <!-- Transparent toggle over full width -->
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent" BorderThickness="0" Opacity="0"/>

                                <Popup Grid.ColumnSpan="2"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border Background="#1E2329"
                                            BorderBrush="#2B3139" BorderThickness="1"
                                            CornerRadius="4"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="200">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#F0B90B"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter Property="BorderBrush" Value="#F0B90B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="CaretBrush" Value="#F0B90B"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F0B90B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TradeBtn" TargetType="Button">
            <Setter Property="Background" Value="#F0B90B"/>
            <Setter Property="Foreground" Value="#0B0E11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D9A800"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8900A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28 24 28 28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT — Trade Form -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Trade" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Convert currencies at mid-market rate"
                           FontSize="12" Foreground="#848E9C"
                           FontFamily="Segoe UI" Margin="0 4 0 24"/>

                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1" Padding="24">
                    <StackPanel>

                        <!-- From -->
                        <TextBlock Text="FROM" Style="{StaticResource Label}"/>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableCurrencies}"
                                      SelectedItem="{Binding FromCurrency}"
                                      Style="{StaticResource DarkCombo}"/>
                            <!-- Fix 1: bind to AmountText (string) not Amount (double) -->
                            <TextBox Grid.Column="2"
                                     Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"/>
                        </Grid>

                        <!-- Available balance -->
                        <Border Visibility="{Binding HasFromBalance, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0 0 0 12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Available: " Foreground="#848E9C"
                                           FontSize="12" FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding FromBalance, StringFormat=N4}"
                                           Foreground="#F0B90B" FontWeight="SemiBold"
                                           FontSize="12" FontFamily="Segoe UI"/>
                                <TextBlock Text=" " Foreground="#848E9C" FontSize="12"/>
                                <TextBlock Text="{Binding FromCurrency}"
                                           Foreground="#848E9C" FontSize="12" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- Swap arrow -->
                        <Border HorizontalAlignment="Center" Margin="0 0 0 8">
                            <TextBlock Text="⇅" FontSize="20" Foreground="#F0B90B"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <!-- To -->
                        <TextBlock Text="TO" Style="{StaticResource Label}"/>
                        <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                                  SelectedItem="{Binding ToCurrency}"
                                  Style="{StaticResource DarkCombo}"
                                  Margin="0 0 0 12"/>

                        <!-- Fix 2: live conversion rate preview -->
                        <Border Visibility="{Binding HasPreviewRate, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="#1A2030" CornerRadius="4"
                                Padding="12 8" Margin="0 0 0 16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Rate:  " Foreground="#848E9C"
                                           FontSize="12" FontFamily="Segoe UI"/>
                                <TextBlock Text="{Binding PreviewRate}"
                                           Foreground="#F0B90B" FontWeight="SemiBold"
                                           FontSize="12" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>

                        <!-- Error -->
                        <Border Background="#2A1A1A" CornerRadius="4"
                                Padding="12 8" Margin="0 0 0 16"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#F6465D"
                                       FontFamily="Segoe UI" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Button -->
                        <Button Content="Convert Now"
                                Command="{Binding PerformExchangeCommand}"
                                Style="{StaticResource TradeBtn}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT — Result Panel -->
            <StackPanel Grid.Column="2"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibilityConverter}}">

                <TextBlock Text="Result" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Conversion summary" FontSize="12"
                           Foreground="#848E9C" FontFamily="Segoe UI"
                           Margin="0 4 0 24"/>

                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1" Padding="24">
                    <StackPanel>

                        <TextBlock Text="CONVERTED AMOUNT" Style="{StaticResource Label}"/>
                        <TextBlock Text="{Binding ResultAmount, StringFormat=N4}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#0ECB81" FontFamily="Segoe UI"
                                   Margin="0 0 0 24"/>

                        <Border Height="1" Background="#1E2329" Margin="0 0 0 24"/>

                        <TextBlock Text="RATE" Style="{StaticResource Label}"
                                   Margin="0 0 0 8"/>

                        <Border Background="#1E2329" CornerRadius="6" Padding="14 12" Margin="0 0 0 24">
                            <TextBlock Text="{Binding ResultRate}"
                                       FontWeight="SemiBold" Foreground="#F0B90B"
                                       FontFamily="Segoe UI" FontSize="14"/>
                        </Border>

                        <Border Height="1" Background="#1E2329" Margin="0 0 0 16"/>

                        <Grid>
                            <TextBlock Text="EXECUTED AT" Style="{StaticResource Label}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ResultTimestamp, StringFormat='yyyy-MM-dd  HH:mm:ss'}"
                                       Foreground="#848E9C" FontFamily="Segoe UI"
                                       FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
