<UserControl x:Class="CurrencyExchange.Client.Views.ExchangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B0E11">

    <UserControl.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#848E9C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
        </Style>

        <!-- This targets the individual items INSIDE the dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="CaretBrush" Value="#F0B90B"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F0B90B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TradeBtn" TargetType="Button">
            <Setter Property="Background" Value="#F0B90B"/>
            <Setter Property="Foreground" Value="#0B0E11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D9A800"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8900A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28 24 28 28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT — Trade Form -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Trade" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Convert currencies at mid-market rate"
                           FontSize="12" Foreground="#848E9C"
                           FontFamily="Segoe UI" Margin="0 4 0 24"/>

                <!-- Trade Card -->
                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1"
                        Padding="24">
                    <StackPanel>

                        <!-- From -->
                        <TextBlock Text="FROM" Style="{StaticResource Label}"/>
                        <Grid Margin="0 0 0 16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableCurrencies}"
                                      SelectedItem="{Binding FromCurrency}"
                                      Style="{StaticResource DarkCombo}"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"/>
                        </Grid>

                        <!-- Swap arrow -->
                        <Border HorizontalAlignment="Center" Margin="0 0 0 16">
                            <TextBlock Text="⇅" FontSize="20" Foreground="#F0B90B"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <!-- To -->
                        <TextBlock Text="TO" Style="{StaticResource Label}"/>
                        <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                                  SelectedItem="{Binding ToCurrency}"
                                  Style="{StaticResource DarkCombo}"
                                  Margin="0 0 0 24"/>

                        <!-- Error -->
                        <Border Background="#2A1A1A" CornerRadius="4"
                                Padding="12 8" Margin="0 0 0 16"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#F6465D"
                                       FontFamily="Segoe UI" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Button -->
                        <Button Content="Convert Now"
                                Command="{Binding PerformExchangeCommand}"
                                Style="{StaticResource TradeBtn}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT — Result Panel -->
            <StackPanel Grid.Column="2"
                        Visibility="{Binding Result, Converter={StaticResource NullToVisibilityConverter}}">

                <TextBlock Text="Result" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Conversion summary" FontSize="12"
                           Foreground="#848E9C" FontFamily="Segoe UI"
                           Margin="0 4 0 24"/>

                <!-- Result Card -->
                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1"
                        Padding="24">
                    <StackPanel>

                        <!-- Converted Amount -->
                        <TextBlock Text="CONVERTED AMOUNT" Style="{StaticResource Label}"/>
                        <TextBlock Text="{Binding Result.Amount, StringFormat=N4}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#0ECB81"
                                   FontFamily="Segoe UI"
                                   Margin="0 0 0 24"/>

                        <!-- Divider -->
                        <Border Height="1" Background="#1E2329" Margin="0 0 0 24"/>

                        <!-- Rates Used -->
                        <TextBlock Text="RATES USED" Style="{StaticResource Label}"
                                   Margin="0 0 0 12"/>

                        <ItemsControl ItemsSource="{Binding Result.Rate}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E2329" CornerRadius="6"
                                            Padding="14 12" Margin="0 0 0 8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Code}"
                                                           FontWeight="Bold"
                                                           Foreground="#EAECEF"
                                                           FontFamily="Segoe UI"
                                                           FontSize="13"/>
                                                <TextBlock Text="{Binding Currency}"
                                                           Foreground="#848E9C"
                                                           FontFamily="Segoe UI"
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Mid, StringFormat=N4}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F0B90B"
                                                           FontFamily="Segoe UI"
                                                           FontSize="14"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="PLN"
                                                           Foreground="#848E9C"
                                                           FontFamily="Segoe UI"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Divider -->
                        <Border Height="1" Background="#1E2329" Margin="0 16 0 16"/>

                        <!-- Timestamp -->
                        <Grid>
                            <TextBlock Text="EXECUTED AT" Style="{StaticResource Label}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Result.Timestamp, StringFormat='yyyy-MM-dd  HH:mm:ss'}"
                                       Foreground="#848E9C" FontFamily="Segoe UI"
                                       FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>