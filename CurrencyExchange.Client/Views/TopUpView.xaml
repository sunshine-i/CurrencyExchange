<UserControl x:Class="CurrencyExchange.Client.Views.TopUpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B0E11">

    <UserControl.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#848E9C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2B3139"/>
                                <Setter Property="Foreground" Value="#F0B90B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="CaretBrush" Value="#F0B90B"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F0B90B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#F0B90B"/>
            <Setter Property="Foreground" Value="#0B0E11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D9A800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28 24 28 28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT — Top Up Form -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Top Up" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Add funds to your account balance"
                           FontSize="12" Foreground="#848E9C"
                           FontFamily="Segoe UI" Margin="0 4 0 24"/>

                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1" Padding="24">
                    <StackPanel>

                        <!-- Currency -->
                        <TextBlock Text="CURRENCY" Style="{StaticResource Label}"/>
                        <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                                  SelectedItem="{Binding SelectedCurrency}"
                                  Style="{StaticResource DarkCombo}"
                                  Margin="0 0 0 16"/>

                        <!-- Amount -->
                        <TextBlock Text="AMOUNT" Style="{StaticResource Label}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 Margin="0 0 0 24"/>

                        <!-- Error -->
                        <Border Background="#2A1A1A" CornerRadius="4" Padding="12 8" Margin="0 0 0 12"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F6465D"
                                       FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Success -->
                        <Border Background="#162320" CornerRadius="4" Padding="12 8" Margin="0 0 0 12"
                                Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="#0ECB81"
                                       FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Button -->
                        <Button Content="Add Funds"
                                Command="{Binding TopUpCommand}"
                                Style="{StaticResource PrimaryBtn}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT — Current Balances -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Your Balances" FontSize="20" FontWeight="Bold"
                           Foreground="#EAECEF" FontFamily="Segoe UI"/>
                <TextBlock Text="Current holdings across all currencies"
                           FontSize="12" Foreground="#848E9C"
                           FontFamily="Segoe UI" Margin="0 4 0 24"/>

                <Border Background="#161A1E" CornerRadius="8"
                        BorderBrush="#1E2329" BorderThickness="1" Padding="8">
                    <ItemsControl ItemsSource="{Binding Balances}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16 14" BorderThickness="0 0 0 1" BorderBrush="#1E2329">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="16"
                                                    Background="#1E2329" Margin="0 0 10 0">
                                                <TextBlock Text="{Binding CurrencyCode}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="#F0B90B"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding CurrencyCode}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       Foreground="#EAECEF" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat=N4}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="#0ECB81" FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
