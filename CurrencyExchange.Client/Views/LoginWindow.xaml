<Window x:Class="CurrencyExchange.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:CurrencyExchange.Client.Helpers"
        Title="CurrencyExchange — Login"
        Height="480" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B0E11">

    <Window.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#848E9C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0 0 0 6"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="CaretBrush" Value="#F0B90B"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#F0B90B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E2329"/>
            <Setter Property="Foreground" Value="#EAECEF"/>
            <Setter Property="BorderBrush" Value="#2B3139"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12 0"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#F0B90B"/>
            <Setter Property="Foreground" Value="#0B0E11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D9A800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F0B90B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontFamily="{TemplateBinding FontFamily}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="40 36">
        <StackPanel>
            <!-- Logo -->
            <TextBlock Text="Currency Exchange" FontSize="22" FontWeight="Bold"
                       Foreground="#EAECEF" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0 0 0 4"/>
            <TextBlock Text="Sign in to your account" FontSize="12"
                       Foreground="#848E9C" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" Margin="0 0 0 32"/>

            <!-- Username -->
            <TextBlock Text="USERNAME" Style="{StaticResource Label}"/>
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}"
                     Margin="0 0 0 16"/>

            <!-- Password -->
            <TextBlock Text="PASSWORD" Style="{StaticResource Label}"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource DarkPasswordBox}"
                         Margin="0 0 0 20"/>

            <!-- Error -->
            <Border Background="#2A1A1A" CornerRadius="4" Padding="12 8" Margin="0 0 0 16"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F6465D"
                           FontFamily="Segoe UI" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Login button -->
            <Button Content="Sign In"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    Margin="0 0 0 20"/>

            <!-- Register link -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Don't have an account? "
                           Foreground="#848E9C" FontSize="12" FontFamily="Segoe UI"/>
                <Button Content="Register"
                        Command="{Binding GoToRegisterCommand}"
                        Style="{StaticResource LinkBtn}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
