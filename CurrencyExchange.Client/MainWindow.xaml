<Window x:Class="CurrencyExchange.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CurrencyExchange.Client.Views"
        xmlns:viewmodels="clr-namespace:CurrencyExchange.Client.ViewModels"
        Title="CryptoExchange" Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0B0E11"
        BorderThickness="0">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:ExchangeRatesViewModel}">
            <views:ExchangeRatesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ExchangeViewModel}">
            <views:ExchangeView/>
        </DataTemplate>

        <!-- Nav Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#848E9C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20 14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3 0 0 0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E2329"/>
                                <Setter Property="Foreground" Value="#EAECEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Foreground" Value="#F0B90B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1E2329"
                                BorderThickness="3 0 0 0"
                                BorderBrush="#F0B90B"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#161A1E"
                BorderThickness="0 0 1 0" BorderBrush="#1E2329">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20 24 20 16"
                        BorderThickness="0 0 0 1" BorderBrush="#1E2329">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Currency Exchange" FontSize="16" FontWeight="Bold"
                                   Foreground="#EAECEF" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="0 8 0 0">
                    <TextBlock Text="MARKETS" FontSize="10" FontWeight="Bold"
                               Foreground="#474D57" Margin="20 12 0 6"
                               FontFamily="Segoe UI"/>

                    <Button Content="📊   Exchange Rates"
                            Command="{Binding ShowRatesCommand}"
                            Style="{StaticResource NavButton}"/>

                    <Button Content="⇄   Trade"
                            Command="{Binding ShowExchangeCommand}"
                            Style="{StaticResource NavButton}"/>
                </StackPanel>

                <!-- Bottom branding -->
                <Border DockPanel.Dock="Bottom" Padding="20 16">
                    <TextBlock Text="Powered by NBP API" FontSize="10"
                               Foreground="#474D57" FontFamily="Segoe UI"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <!-- Top bar -->
            <Border Height="52" VerticalAlignment="Top"
                    Background="#161A1E"
                    BorderThickness="0 0 0 1" BorderBrush="#1E2329">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Margin="0 0 24 0">
                    <Border CornerRadius="4" Background="#1E2329"
                            Padding="10 6" Margin="0 0 12 0">
                        <TextBlock Text="PLN Base" FontSize="12"
                                   Foreground="#F0B90B" FontFamily="Segoe UI"/>
                    </Border>
                    <Ellipse Width="8" Height="8" Fill="#0ECB81" Margin="0 0 6 0"/>
                    <TextBlock Text="Live" FontSize="12" Foreground="#848E9C"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <ContentControl Content="{Binding CurrentView}" Margin="0 52 0 0"/>
        </Grid>
    </Grid>
</Window>